# ============================================
# 企业知识库 — 环境变量配置
# 复制为 .env 并修改实际值
# ============================================

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://kb_user:changeme@localhost:5432/knowledge_base
DATABASE_URL_SYNC=postgresql://kb_user:changeme@localhost:5432/knowledge_base
DB_PASSWORD=changeme

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ──
ES_HOST=http://localhost:9200
ES_USER=
ES_PASSWORD=

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=knowledge-base
MINIO_SECURE=false

# ── JWT ──
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 飞书 ──
FEISHU_ENABLED=false
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxx

# ── 钉钉 ──
DINGTALK_ENABLED=false
DINGTALK_APP_KEY=dingxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_CORP_ID=dingxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_TOKEN=xxxxxxxxxxxx

# ── LLM ──
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:14b
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── Embedding ──
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32

# ── Reranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5
RERANKER_DEVICE=cpu

# ── 分块 ──
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── 应用 ──
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
